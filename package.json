{
  "name": "chime-language-linter",
  "version": "1.0.0",
  "description": "A text analysis tool that enforces Chime People Development content style rules",
  "type": "module",
  "scripts": {
    "build": "npm run build:cli && npm run build:web",
    "build:cli": "esbuild src/cli/index.ts --bundle --platform=node --format=esm --outfile=dist/cli/chime-lint.mjs --banner:js='#!/usr/bin/env node'",
    "build:web": "vite build",
    "dev:web": "vite",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "bin": {
    "chime-lint": "./dist/cli/chime-lint.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
